  "receipt_invariants": {
    "description": "Properties that MUST hold for every generated receipt",
    "rules": [
      "receipt.receipt_id is non-empty and unique across the session",
      "receipt.verdict is one of: ALLOW, DENY, ESCALATE",
      "receipt.timestamp is monotonically increasing within a session",
      "receipt.timestamp is ISO 8601 / RFC 3339 format",
      "receipt.signature is a valid Ed25519 or ECDSA signature over the receipt payload",
      "receipt.payload_hash is SHA-256 of the JCS-canonicalized JSON payload",
      "receipt.reason_code is null for ALLOW, or a registered code from reason-codes-v1.json",
      "receipt.lamport is a positive integer, strictly increasing within a ProofGraph",
      "receipt.effect_id matches the submitted effect's effect_id",
      "receipt.principal matches the submitted principal",
      "receipt must be produced even for DENY verdicts (fail-closed observability)"
    ]
  },
  "hash_chain_vectors": [
    {
      "id": "CHAIN-001",
      "description": "Three-node ProofGraph chain with monotonic Lamport clock",
      "nodes": [
        {"kind": "ATTESTATION", "lamport": 1, "payload": "{\"verdict\":\"ALLOW\"}", "parents": []},
        {"kind": "INTENT", "lamport": 2, "payload": "{\"intent_id\":\"i1\"}", "parents": ["node-0-hash"]},
        {"kind": "EFFECT", "lamport": 3, "payload": "{\"result\":\"ok\"}", "parents": ["node-1-hash"]}
      ],
      "invariants": [
        "Each node hash includes parent hashes",
        "Lamport values are strictly increasing",
        "Removing any node breaks the chain verification"
      ]
    },
    {
      "id": "CHAIN-002",
      "description": "Forked ProofGraph — two independent branches from same root",
      "nodes": [
        {"kind": "ATTESTATION", "lamport": 1, "payload": "{\"verdict\":\"ALLOW\"}", "parents": []},
        {"kind": "INTENT", "lamport": 2, "payload": "{\"intent_id\":\"fork-a\"}", "parents": ["node-0-hash"]},
        {"kind": "INTENT", "lamport": 3, "payload": "{\"intent_id\":\"fork-b\"}", "parents": ["node-0-hash"]},
        {"kind": "MERGE", "lamport": 4, "payload": "{\"merged\":true}", "parents": ["node-1-hash", "node-2-hash"]}
      ],
      "invariants": [
        "Forked branches have independent Lamport sequences",
        "Merge node references both branch tips as parents",
        "Global Lamport ordering is maintained"
      ]
    },
    {
      "id": "CHAIN-003",
      "description": "Single-node degenerate chain — genesis only",
      "nodes": [
        {"kind": "ATTESTATION", "lamport": 1, "payload": "{\"verdict\":\"ALLOW\"}", "parents": []}
      ],
      "invariants": [
        "Single-node chain is valid",
        "Node has no parents",
        "Verification succeeds trivially"
      ]
    }
