{
  "test_suite": "helm-conformance-v1",
  "version": "1.0.0",
  "description": "Conformance test vectors for HELM governance implementations",
  "vectors": [
    {
      "id": "ALLOW-001",
      "description": "Basic allow verdict for a legitimate file read",
      "input": {
        "effect": {"effect_type": "file_read", "effect_id": "eff-001", "params": {"path": "/data/report.csv"}},
        "principal": "agent:analyst",
        "context": {"environment": "production"}
      },
      "expected": {
        "verdict": "ALLOW",
        "reason_code": null,
        "receipt_present": true,
        "intent_present": true
      }
    },
    {
      "id": "DENY-001",
      "description": "Deny due to policy violation — writing to system directory",
      "input": {
        "effect": {"effect_type": "file_write", "effect_id": "eff-002", "params": {"path": "/etc/passwd"}},
        "principal": "agent:assistant",
        "context": {}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "POLICY_VIOLATION",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "DENY-002",
      "description": "Deny due to budget exceeded",
      "input": {
        "effect": {"effect_type": "api_call", "effect_id": "eff-003", "params": {"url": "https://api.openai.com/v1/chat/completions"}, "budget_id": "budget-001"},
        "principal": "agent:spender",
        "context": {}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "BUDGET_EXCEEDED",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "DENY-003",
      "description": "Deny due to missing requirement",
      "input": {
        "effect": {"effect_type": "deploy", "effect_id": "eff-004", "params": {"target": "production"}},
        "principal": "agent:deployer",
        "context": {}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "MISSING_REQUIREMENT",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "DENY-004",
      "description": "Deny due to sandbox violation",
      "input": {
        "effect": {"effect_type": "exec", "effect_id": "eff-005", "params": {"command": "rm -rf /"}},
        "principal": "agent:runner",
        "context": {}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "SANDBOX_VIOLATION",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "ESCALATE-001",
      "description": "Escalate due to temporal intervention",
      "input": {
        "effect": {"effect_type": "financial_transfer", "effect_id": "eff-006", "params": {"amount_cents": 100000, "currency": "USD"}},
        "principal": "agent:finance",
        "context": {}
      },
      "expected": {
        "verdict": "ESCALATE",
        "reason_code": "TEMPORAL_INTERVENTION",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "DENY-PDP-001",
      "description": "Deny from external PDP returning explicit deny",
      "input": {
        "effect": {"effect_type": "data_export", "effect_id": "eff-007", "params": {"format": "csv", "destination": "external"}},
        "principal": "agent:exporter",
        "context": {"jurisdiction": "EU"}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "PDP_DENY",
        "receipt_present": true,
        "intent_present": false
      }
    },
    {
      "id": "DENY-FAILCLOSED-001",
      "description": "Deny due to PDP being unreachable — fail-closed invariant",
      "input": {
        "effect": {"effect_type": "api_call", "effect_id": "eff-008", "params": {}},
        "principal": "agent:caller",
        "context": {}
      },
      "pdp_behavior": "unreachable",
      "expected": {
        "verdict": "DENY",
        "reason_code": "PDP_ERROR",
        "receipt_present": true,
        "intent_present": false
      }
    }
  ],
  "receipt_invariants": {
    "description": "Properties that MUST hold for every generated receipt",
    "rules": [
      "receipt.receipt_id is non-empty and unique",
      "receipt.verdict matches the returned verdict",
      "receipt.timestamp is monotonically increasing within a session",
      "receipt.signature is a valid Ed25519 or ECDSA signature over the receipt payload",
      "receipt.payload_hash is SHA-256 of the canonical JSON payload",
      "receipt.reason_code is a registered code from reason-codes-v1.json",
      "receipt.lamport is strictly increasing within a ProofGraph"
    ]
  },
  "hash_chain_vectors": [
    {
      "id": "CHAIN-001",
      "description": "Three-node ProofGraph chain with monotonic Lamport clock",
      "nodes": [
        {"kind": "ATTESTATION", "lamport": 1, "payload": "{\"verdict\":\"ALLOW\"}", "parents": []},
        {"kind": "INTENT", "lamport": 2, "payload": "{\"intent_id\":\"i1\"}", "parents": ["node-0-hash"]},
        {"kind": "EFFECT", "lamport": 3, "payload": "{\"result\":\"ok\"}", "parents": ["node-1-hash"]}
      ],
      "invariants": [
        "Each node hash includes parent hashes",
        "Lamport values are strictly increasing",
        "Removing any node breaks the chain verification"
      ]
    }
  ],
  "golden_receipts": [
    {
      "id": "GOLDEN-RECEIPT-001",
      "description": "Golden receipt for ALLOW verdict — offline verification reference",
      "receipt": {
        "receipt_version": "1.0",
        "receipt_id": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "decision_id": "dec-golden-001",
        "effect_id": "eff-golden-001",
        "verdict": "ALLOW",
        "principal": "agent:test-principal",
        "tool": "file_read",
        "action": "read /data/test.csv",
        "timestamp": "2026-01-01T00:00:00Z",
        "lamport": 1,
        "proofgraph_node": "pgnode-golden-001",
        "payload_hash": "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
        "metadata": {"environment": "test", "spec_version": "1.0.0"}
      },
      "verification_steps": [
        "Recompute receipt_id from all fields except receipt_id itself",
        "Verify receipt_id matches SHA-256 of canonical JSON",
        "Verify verdict is a canonical enum value",
        "Verify lamport is a positive integer",
        "Verify timestamp is RFC 3339"
      ]
    }
  ],
  "lifecycle_fixtures": [
    {
      "id": "LIFECYCLE-001",
      "description": "Happy path: SUBMITTED → APPROVED → EXECUTING → COMPLETED",
      "transitions": [
        {"from": null, "to": "SUBMITTED", "trigger": "Submit(effect)"},
        {"from": "SUBMITTED", "to": "APPROVED", "trigger": "PDP returns ALLOW"},
        {"from": "APPROVED", "to": "EXECUTING", "trigger": "Execute(effectId)"},
        {"from": "EXECUTING", "to": "COMPLETED", "trigger": "Complete(effectId, evidencePackId)"}
      ]
    },
    {
      "id": "LIFECYCLE-002",
      "description": "Deny path: SUBMITTED → DENIED",
      "transitions": [
        {"from": null, "to": "SUBMITTED", "trigger": "Submit(effect)"},
        {"from": "SUBMITTED", "to": "DENIED", "trigger": "PDP returns DENY"}
      ]
    },
    {
      "id": "LIFECYCLE-003",
      "description": "Escalation path: SUBMITTED → ESCALATED → APPROVED or DENIED",
      "transitions": [
        {"from": null, "to": "SUBMITTED", "trigger": "Submit(effect)"},
        {"from": "SUBMITTED", "to": "ESCALATED", "trigger": "PDP returns ESCALATE"},
        {"from": "ESCALATED", "to": "APPROVED", "trigger": "Human approves"},
        {"from": "ESCALATED", "to": "DENIED", "trigger": "Human denies or timeout"}
      ]
    }
  ],
  "jurisdiction_fixtures": [
    {
      "id": "JURISDICTION-001",
      "description": "EU GDPR jurisdiction deny with extended reason code",
      "input": {
        "effect": {"effect_type": "data_export", "effect_id": "eff-j001", "params": {"destination": "us-east-1", "data_class": "personal"}},
        "principal": "agent:exporter",
        "context": {"jurisdiction": "EU"}
      },
      "expected": {
        "verdict": "DENY",
        "reason_code": "JURISDICTION_VIOLATION",
        "receipt_present": true,
        "active_packs": ["eu-gdpr"]
      }
    }
  ],
  "evidence_bundle_fixture": {
    "id": "EVIDENCE-001",
    "description": "Minimal valid EvidencePack structure",
    "required_fields": [
      "schema_version",
      "session_id",
      "receipts",
      "decisions",
      "active_bundles",
      "created_at"
    ],
    "sample": {
      "schema_version": "1.0.0",
      "session_id": "ses-golden-001",
      "receipts": ["urn:helm:receipt:e3b0c44298fc1c..."],
      "decisions": ["urn:helm:decision:dec-golden-001"],
      "active_bundles": [
        {"name": "corporate-baseline", "version": "1.0.0", "content_hash": "sha256:abc123"}
      ],
      "created_at": "2026-01-01T00:00:00Z",
      "spec_version": "1.0.0"
    }
  }
}
