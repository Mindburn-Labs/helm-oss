{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/infra/load_balancer.json",
  "title": "Load Balancer Effect",
  "description": "Creates or updates a load balancer",
  "type": "object",
  "required": ["effect_id", "name", "region"],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "infra.do.create_load_balancer"
    },
    "name": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "forwarding_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entry_protocol": {"type": "string", "enum": ["http", "https", "tcp"]},
          "entry_port": {"type": "integer"},
          "target_protocol": {"type": "string"},
          "target_port": {"type": "integer"}
        }
      }
    },
    "droplet_ids": {
      "type": "array",
      "items": {"type": "integer"}
    },
    "health_check": {
      "type": "object",
      "properties": {
        "protocol": {"type": "string"},
        "port": {"type": "integer"},
        "path": {"type": "string"}
      }
    }
  },
  "x-helm": {
    "category": "infrastructure",
    "provider": "digitalocean",
    "risk_level": "medium",
    "cost_impact": "recurring"
  }
}
