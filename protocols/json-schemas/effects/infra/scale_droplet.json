{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/infra/scale_droplet.json",
  "title": "Scale Droplet Effect",
  "description": "Resizes an existing DigitalOcean droplet (vertical scaling)",
  "type": "object",
  "required": ["effect_id", "droplet_id", "size"],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "infra.do.scale_droplet"
    },
    "droplet_id": {
      "type": "string",
      "description": "Target droplet ID"
    },
    "size": {
      "type": "string",
      "description": "New droplet size",
      "enum": ["s-1vcpu-1gb", "s-1vcpu-2gb", "s-2vcpu-4gb", "s-4vcpu-8gb", "s-8vcpu-16gb"]
    },
    "resize_disk": {
      "type": "boolean",
      "description": "Also resize disk (cannot be undone)",
      "default": false
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "infrastructure",
    "provider": "digitalocean",
    "risk_level": "medium",
    "requires_approval": true,
    "cost_impact": "recurring",
    "requires_downtime": true,
    "downtime_minutes": 5
  }
}
