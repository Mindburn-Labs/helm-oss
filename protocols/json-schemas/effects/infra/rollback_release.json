{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/infra/rollback_release.json",
  "title": "Rollback Release Effect",
  "description": "Rolls back to a previous release",
  "type": "object",
  "required": ["effect_id", "target_host"],
  "properties": {
    "effect_id": {
      "type": "string",
      "const": "infra.helm.rollback_release"
    },
    "target_host": {
      "type": "string",
      "description": "Target host IP or hostname"
    },
    "target_sha": {
      "type": "string",
      "description": "Optional specific SHA to rollback to (defaults to previous)",
      "pattern": "^[a-f0-9]{40}$"
    },
    "reason": {
      "type": "string",
      "description": "Reason for rollback",
      "enum": ["health_check_failure", "manual", "incident", "drift_detected"]
    }
  },
  "additionalProperties": false,
  "x-helm": {
    "category": "deployment",
    "provider": "helm",
    "risk_level": "medium",
    "requires_approval": false,
    "cost_impact": "none",
    "emergency_effect": true
  }
}
