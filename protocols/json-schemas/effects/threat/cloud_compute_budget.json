{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/threat/cloud_compute_budget.json",
  "title": "Cloud Compute Budget Effect",
  "description": "Consumes cloud compute resources against a tenant budget. Crypto-mining vector.",
  "type": "object",
  "required": ["effect_id", "budget_id"],
  "properties": {
    "effect_id": { "type": "string", "const": "CLOUD_COMPUTE_BUDGET" },
    "budget_id": { "type": "string" },
    "estimated_cost_usd": { "type": "number", "minimum": 0 },
    "resource_type": { "type": "string", "enum": ["compute", "gpu", "storage", "network"] },
    "duration_seconds": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false,
  "x-helm": { "category": "threat", "risk_class": "E2", "approval_level": "none", "reversible": true }
}
