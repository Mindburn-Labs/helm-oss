{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/threat/ci_credential_access.json",
  "title": "CI Credential Access Effect",
  "description": "Accesses CI/CD credentials, signing keys, or deployment secrets. Supply-chain attack vector.",
  "type": "object",
  "required": ["effect_id", "credential_type"],
  "properties": {
    "effect_id": { "type": "string", "const": "CI_CREDENTIAL_ACCESS" },
    "credential_type": { "type": "string", "enum": ["signing_key", "deploy_token", "api_key", "ssh_key", "registry_token"] },
    "ci_system": { "type": "string" },
    "scope": { "type": "string" }
  },
  "additionalProperties": false,
  "x-helm": { "category": "threat", "risk_class": "E4", "approval_level": "dual_control", "reversible": false }
}
