{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://helm.dev/schemas/effects/threat/software_publish.json",
  "title": "Software Publish Effect",
  "description": "Publishes a software artifact to a registry. Irreversible in public registries.",
  "type": "object",
  "required": ["effect_id", "registry", "package_name", "version"],
  "properties": {
    "effect_id": { "type": "string", "const": "SOFTWARE_PUBLISH" },
    "registry": { "type": "string" },
    "package_name": { "type": "string" },
    "version": { "type": "string" },
    "artifact_hash": { "type": "string" }
  },
  "additionalProperties": false,
  "x-helm": { "category": "threat", "risk_class": "E4", "approval_level": "dual_control", "reversible": false }
}
