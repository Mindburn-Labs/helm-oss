{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.sh/schemas/orchestration/StepRun.v1.json",
  "title": "StepRun",
  "description": "Execution record for a single step in a plan",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this step run"
    },
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "plan_id": {
      "type": "string",
      "description": "Reference to the PlanSpec"
    },
    "step_id": {
      "type": "string",
      "description": "Reference to the step within the PlanSpec"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED", "VETOED"]
    },
    "hash": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "description": "Values provided for this step execution"
    },
    "outputs": {
      "type": "object",
      "description": "Results produced by this step"
    },
    "effect_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "effect_id": { "type": "string" },
          "type": { "type": "string" },
          "params": { "type": "object" },
          "status": { "type": "string" },
          "receipt_hash": { "type": "string" }
        },
        "required": ["effect_id", "type", "status"]
      }
    },
    "logs": {
      "type": "string",
      "description": "Execution logs or stdout/stderr summary"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rel": { "type": "string" },
          "hash": { "type": "string" },
          "type": { "type": "string" }
        },
        "required": ["rel", "hash", "type"]
      }
    }
  },
  "required": ["id", "version", "plan_id", "step_id", "status", "hash"]
}
