{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.org/schemas/core/secret_ref.schema.json",
  "title": "SecretRef",
  "description": "Reference to a secret value per Addendum 8.X - secrets MUST be referenced, never embedded",
  "type": "object",
  "required": ["secret_id", "secret_version", "provider", "access_policy_id", "materialization"],
  "additionalProperties": false,
  "properties": {
    "secret_id": {
      "type": "string",
      "description": "Unique identifier for the secret"
    },
    "secret_version": {
      "type": "string",
      "description": "Version of the secret (for rotation tracking)"
    },
    "provider": {
      "type": "string",
      "description": "Secret provider identifier (e.g., 'vault', 'aws-sm', 'gcp-sm')"
    },
    "access_policy_id": {
      "type": "string",
      "description": "Policy governing access to this secret"
    },
    "materialization": {
      "type": "object",
      "description": "Materialization configuration",
      "required": ["mode", "audit"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["RUNTIME_ONLY"],
          "description": "Secrets may only be materialized at runtime"
        },
        "audit": {
          "type": "object",
          "description": "Audit configuration",
          "required": ["secret_ref_hash", "materialization_event_required"],
          "additionalProperties": false,
          "properties": {
            "secret_ref_hash": {
              "type": "string",
              "description": "Hash of the SecretRef for audit correlation"
            },
            "materialization_event_required": {
              "type": "boolean",
              "description": "Whether materialization must emit an event"
            }
          }
        }
      }
    }
  }
}
