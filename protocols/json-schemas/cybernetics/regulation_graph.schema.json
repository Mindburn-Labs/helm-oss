{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.org/schemas/cybernetics/regulation_graph.schema.json",
  "title": "RegulationGraph",
  "description": "Per Section 4.4 - Deterministic mode transition graph with priority-based tie-breaking",
  "type": "object",
  "additionalProperties": false,
  "required": ["graph_id", "name", "modes", "initial_mode_id"],
  "properties": {
    "graph_id": {
      "type": "string",
      "description": "Unique identifier for this regulation graph"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this graph definition"
    },
    "modes": {
      "type": "array",
      "items": {
        "$ref": "https://helm.org/schemas/cybernetics/mode.schema.json"
      },
      "description": "All modes in this regulation graph"
    },
    "initial_mode_id": {
      "type": "string",
      "description": "Mode ID to start in (must have default_mode: true)"
    },
    "essential_variables": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Essential variable IDs this graph regulates"
    },
    "control_loops": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Control loop IDs managed by this graph"
    },
    "transition_policy": {
      "type": "object",
      "description": "Global policies for mode transitions",
      "properties": {
        "tie_breaking_strategy": {
          "type": "string",
          "enum": ["priority", "first_match", "most_specific", "random"],
          "default": "priority",
          "description": "Strategy for resolving multiple matching transitions"
        },
        "min_mode_duration_ms": {
          "type": "integer",
          "description": "Minimum time to stay in a mode before transitioning"
        },
        "max_transitions_per_minute": {
          "type": "integer",
          "description": "Rate limit for mode transitions"
        },
        "transition_cooldown_ms": {
          "type": "integer",
          "description": "Cooldown period after a transition"
        },
        "log_all_transitions": {
          "type": "boolean",
          "default": true,
          "description": "Whether to log all transitions to event log"
        }
      }
    },
    "emergency_policy": {
      "type": "object",
      "description": "Policy for emergency mode activation",
      "properties": {
        "emergency_mode_id": {
          "type": "string",
          "description": "Mode ID to transition to in emergencies"
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "condition": { "type": "string" },
              "severity": { "type": "string" }
            }
          },
          "description": "Conditions that trigger emergency mode"
        },
        "auto_recovery": {
          "type": "boolean",
          "default": false,
          "description": "Whether to auto-recover from emergency mode"
        },
        "recovery_predicate": {
          "type": "string",
          "description": "CEL expression for auto-recovery condition"
        }
      }
    },
    "audit": {
      "type": "object",
      "description": "Audit configuration",
      "properties": {
        "record_state_snapshots": {
          "type": "boolean",
          "default": true,
          "description": "Record essential variable snapshots on transitions"
        },
        "retention_days": {
          "type": "integer",
          "default": 90,
          "description": "Days to retain transition history"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
