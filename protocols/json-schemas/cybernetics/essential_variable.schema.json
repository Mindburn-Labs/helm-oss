{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.org/schemas/cybernetics/essential_variable.schema.json",
  "title": "EssentialVariable",
  "description": "Per Section 4.1 - Observable state dimensions the system regulates",
  "type": "object",
  "additionalProperties": false,
  "required": ["variable_id", "name", "observable", "bounds"],
  "properties": {
    "variable_id": {
      "type": "string",
      "description": "Unique identifier for this essential variable"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what this variable represents"
    },
    "observable": {
      "type": "object",
      "description": "How to observe this variable's current value",
      "required": ["source", "expression"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["ledger", "metrics", "external_api", "computed"],
          "description": "Data source for observation"
        },
        "expression": {
          "type": "string",
          "description": "CEL expression to compute current value from source"
        },
        "sample_interval_ms": {
          "type": "integer",
          "minimum": 100,
          "description": "Sampling interval in milliseconds"
        }
      }
    },
    "bounds": {
      "type": "object",
      "description": "Acceptable range for homeostasis",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["numeric_range", "set_membership", "boolean", "threshold"],
          "description": "Type of bounds check"
        },
        "min": {
          "type": "number",
          "description": "Minimum acceptable value (for numeric_range)"
        },
        "max": {
          "type": "number",
          "description": "Maximum acceptable value (for numeric_range)"
        },
        "target": {
          "type": "number",
          "description": "Target value for regulation"
        },
        "allowed_values": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed values (for set_membership)"
        },
        "threshold": {
          "type": "number",
          "description": "Threshold value (for threshold type)"
        },
        "comparison": {
          "type": "string",
          "enum": ["lt", "lte", "gt", "gte", "eq"],
          "description": "Comparison operator for threshold"
        }
      }
    },
    "alarm": {
      "type": "object",
      "description": "Alarm configuration when bounds are violated",
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "critical"],
          "description": "Severity level of alarm"
        },
        "cooldown_ms": {
          "type": "integer",
          "description": "Minimum time between alarm firings"
        },
        "notification_channels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Channels to notify on alarm"
        }
      }
    },
    "unit": {
      "type": "string",
      "description": "Unit of measurement (e.g., 'USD', 'percentage', 'count')"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Classification tags for grouping"
    }
  }
}
