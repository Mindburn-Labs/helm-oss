{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "helm://schemas/compliance/ComplianceControl.v1.json",
  "title": "ComplianceControl.v1",
  "description": "Definition of a compliance control requirement.",
  "type": "object",
  "required": ["control_id", "framework", "title", "description", "category", "severity"],
  "properties": {
    "control_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_-]+$"
    },
    "framework": {
      "type": "string"
    },
    "section": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": ["access_control", "data_privacy", "audit_log", "encryption", "incident_response", "change_management", "resilience"]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "automated_check": {
      "type": "boolean"
    },
    "remediation": {
      "type": "string"
    }
  }
}
