{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.org/schemas/receipts/model_invocation_receipt.v1.schema.json",
  "title": "ModelInvocationReceipt.v1",
  "description": "Mandatory receipt for every LLM/model invocation. Ensures auditability and replay. Per Section 2.2 of the semantic constitution.",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_id", "invoked_at", "provider", "model", "prompt_hash", "output_hash", "status"],
  "properties": {
    "receipt_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this receipt"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "invoked_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the model was invoked"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the invocation completed"
    },
    "latency_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Total latency in milliseconds"
    },
    "provider": {
      "type": "object",
      "required": ["provider_id", "provider_type"],
      "properties": {
        "provider_id": {
          "type": "string",
          "description": "Unique identifier for the provider (e.g., 'openai', 'anthropic', 'local-ollama')"
        },
        "provider_type": {
          "type": "string",
          "enum": ["api", "local", "hybrid"]
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "API endpoint used (redacted for security if needed)"
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["model_id", "model_version"],
      "properties": {
        "model_id": {
          "type": "string",
          "description": "Model identifier (e.g., 'gpt-4-turbo', 'claude-3-opus')"
        },
        "model_version": {
          "type": "string",
          "description": "Specific version or snapshot"
        },
        "capability_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "structured_output",
              "tool_use",
              "vision",
              "code_execution",
              "long_context",
              "reasoning"
            ]
          }
        }
      }
    },
    "fingerprint": {
      "type": "object",
      "description": "Fingerprint for drift detection",
      "properties": {
        "weights_hash": {
          "type": "string",
          "description": "For local models: SHA-256 of model weights"
        },
        "image_digest": {
          "type": "string",
          "description": "For containerized local models: container image digest"
        },
        "api_version": {
          "type": "string",
          "description": "For API models: API version string"
        },
        "system_prompt_hash": {
          "type": "string",
          "description": "Hash of system prompt if used"
        }
      }
    },
    "prompt_hash": {
      "type": "string",
      "description": "SHA-256 hash of the canonical prompt"
    },
    "input_bundle_hash": {
      "type": "string",
      "description": "SHA-256 hash of the full input bundle (messages + context)"
    },
    "tool_manifest_hash": {
      "type": "string",
      "description": "SHA-256 hash of the tools available to the model during this invocation"
    },
    "output_hash": {
      "type": "string",
      "description": "SHA-256 hash of the raw model output"
    },
    "parsed_output_hash": {
      "type": "string",
      "description": "SHA-256 hash of the parsed/structured output"
    },
    "status": {
      "type": "string",
      "enum": ["success", "error", "timeout", "rate_limited", "filtered"],
      "description": "Outcome of the invocation"
    },
    "error": {
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" }
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "cost_estimate": {
          "type": "object",
          "properties": {
            "amount": { "type": "number" },
            "currency": { "type": "string" }
          }
        }
      }
    },
    "determinism_markers": {
      "type": "object",
      "properties": {
        "temperature": { "type": "number" },
        "seed": { "type": "integer" },
        "top_p": { "type": "number" },
        "deterministic_mode": { "type": "boolean" }
      }
    },
    "replay_policy": {
      "type": "object",
      "description": "How this invocation should be handled during replay",
      "properties": {
        "resample_allowed": {
          "type": "boolean",
          "default": false,
          "description": "If true, replay may resample the model"
        },
        "cached_response_id": {
          "type": "string",
          "description": "Reference to cached response for deterministic replay"
        }
      }
    },
    "content_hash": {
      "type": "string",
      "description": "SHA-256 hash of the canonical JSON representation"
    }
  }
}
