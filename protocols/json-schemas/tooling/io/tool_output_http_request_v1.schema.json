{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_output_http_request_v1.schema.json",
  "title": "HttpRequestOutput",
  "description": "Output schema for tool http.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "status",
    "completed_at"
  ],
  "properties": {
    "completed_at": {
      "description": "ISO 8601 completion timestamp",
      "format": "date-time",
      "type": "string"
    },
    "cost_units": {
      "minimum": 0,
      "type": "integer"
    },
    "error": {
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "latency_ms": {
      "minimum": 0,
      "type": "integer"
    },
    "output_hash": {
      "description": "SHA-256 hash of the canonical output payload",
      "type": "string"
    },
    "request_id": {
      "description": "Echoed request_id from input",
      "format": "uuid",
      "type": "string"
    },
    "response_body_ref_hash": {
      "type": "string"
    },
    "response_bytes": {
      "minimum": 0,
      "type": "integer"
    },
    "response_headers": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "status": {
      "enum": [
        "success",
        "error",
        "timeout",
        "rate_limited"
      ],
      "type": "string"
    },
    "status_code": {
      "type": "integer"
    }
  }
}
