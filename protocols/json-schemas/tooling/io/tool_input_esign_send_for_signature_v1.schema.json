{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_input_esign_send_for_signature_v1.schema.json",
  "title": "EsignSend_for_signatureInput",
  "description": "Input schema for tool esign.send_for_signature (KERNEL, IRREVERSIBLE_WRITE)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "connector_instance_id",
    "idempotency_key",
    "doc_ref_hash",
    "signers"
  ],
  "properties": {
    "connector_instance_id": {
      "description": "Bound connector instance (ESIGN_PROVIDER)",
      "type": "string"
    },
    "doc_ref_hash": {
      "description": "SHA-256 content hash",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "idempotency_key": {
      "description": "Idempotency key derived from: doc_ref_hash, signers, idempotency_key",
      "type": "string"
    },
    "request_id": {
      "description": "Unique request identifier for tracing",
      "format": "uuid",
      "type": "string"
    },
    "signers": {
      "description": "List of signer emails",
      "items": {
        "format": "email",
        "type": "string"
      },
      "type": "array"
    }
  }
}
