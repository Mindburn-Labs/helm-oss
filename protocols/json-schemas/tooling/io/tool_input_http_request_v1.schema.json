{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_input_http_request_v1.schema.json",
  "title": "HttpRequestInput",
  "description": "Input schema for tool http.request (KERNEL, READ_ONLY)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "method",
    "url"
  ],
  "properties": {
    "body_ref_hash": {
      "description": "Content-addressed body reference",
      "type": "string"
    },
    "headers": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "method": {
      "enum": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "HEAD",
        "OPTIONS"
      ],
      "type": "string"
    },
    "request_id": {
      "description": "Unique request identifier for tracing",
      "format": "uuid",
      "type": "string"
    },
    "url": {
      "format": "uri",
      "type": "string"
    }
  }
}
