{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_input_dns_record_upsert_v1.schema.json",
  "title": "DnsRecordUpsertInput",
  "description": "Input schema for tool dns.record.upsert (KERNEL, IRREVERSIBLE_WRITE)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "connector_instance_id",
    "idempotency_key",
    "zone",
    "record_name",
    "record_type",
    "record_value"
  ],
  "properties": {
    "connector_instance_id": {
      "description": "Bound connector instance (DNS_PROVIDER)",
      "type": "string"
    },
    "idempotency_key": {
      "description": "Idempotency key derived from: zone, record_name, record_type, record_value",
      "type": "string"
    },
    "record_name": {
      "description": "DNS record name",
      "type": "string"
    },
    "record_type": {
      "description": "DNS record type",
      "enum": [
        "A",
        "AAAA",
        "CNAME",
        "MX",
        "TXT",
        "SRV",
        "NS"
      ],
      "type": "string"
    },
    "record_value": {
      "description": "DNS record value",
      "type": "string"
    },
    "request_id": {
      "description": "Unique request identifier for tracing",
      "format": "uuid",
      "type": "string"
    },
    "zone": {
      "description": "DNS zone name",
      "type": "string"
    }
  }
}
