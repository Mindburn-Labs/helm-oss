{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_input_email_send_v1.schema.json",
  "title": "EmailSendInput",
  "description": "Input schema for tool email.send (KERNEL, REVERSIBLE_WRITE)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "connector_instance_id",
    "idempotency_key",
    "to",
    "subject",
    "body_ref_hash"
  ],
  "properties": {
    "body_ref_hash": {
      "description": "SHA-256 content hash",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "connector_instance_id": {
      "description": "Bound connector instance (EMAIL_PROVIDER)",
      "type": "string"
    },
    "idempotency_key": {
      "description": "Idempotency key derived from: to, subject, body_ref_hash",
      "type": "string"
    },
    "request_id": {
      "description": "Unique request identifier for tracing",
      "format": "uuid",
      "type": "string"
    },
    "subject": {
      "description": "Email subject line",
      "type": "string"
    },
    "to": {
      "description": "Recipient email address",
      "format": "email",
      "type": "string"
    }
  }
}
