{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "helm://schemas/tooling/io/tool_input_proof_attach_v1.schema.json",
  "title": "ProofAttachInput",
  "description": "Input schema for tool proof.attach (KERNEL, REVERSIBLE_WRITE)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "idempotency_key",
    "subject_ref",
    "artifact_ref_hash"
  ],
  "properties": {
    "artifact_ref_hash": {
      "description": "SHA-256 content hash",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "type": "string"
    },
    "idempotency_key": {
      "description": "Idempotency key derived from: subject_ref, artifact_ref_hash",
      "type": "string"
    },
    "request_id": {
      "description": "Unique request identifier for tracing",
      "format": "uuid",
      "type": "string"
    },
    "subject_ref": {
      "description": "Content-addressed reference",
      "type": "string"
    }
  }
}
