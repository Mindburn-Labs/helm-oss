{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helm.peycheff.com/schemas/access/OperatorAccessPolicy.v1.json",
  "title": "OperatorAccessPolicy",
  "description": "Zero-trust operator access policy with break-glass protocol support",
  "type": "object",
  "required": ["version", "policy_id", "access_tiers"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy_id": {
      "type": "string",
      "pattern": "^oap-[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "description": {
      "type": "string"
    },
    "access_tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/AccessTier"
      }
    },
    "break_glass": {
      "$ref": "#/$defs/BreakGlassConfig"
    },
    "audit_config": {
      "$ref": "#/$defs/AuditConfig"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "created_by": {"type": "string"}
      }
    }
  },
  "$defs": {
    "AccessTier": {
      "type": "object",
      "required": ["tier_id", "name", "permissions"],
      "properties": {
        "tier_id": {
          "type": "string",
          "pattern": "^tier-[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "enum": ["viewer", "operator", "admin", "emergency"]
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "read:packs",
              "write:packs",
              "execute:packs",
              "read:policies",
              "write:policies",
              "read:audit",
              "write:config",
              "emergency:override",
              "emergency:disable_perimeter"
            ]
          }
        },
        "constraints": {
          "type": "object",
          "properties": {
            "require_mfa": {"type": "boolean", "default": true},
            "require_justification": {"type": "boolean", "default": false},
            "max_session_duration_seconds": {"type": "integer", "minimum": 60},
            "allowed_ip_ranges": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        },
        "approval_required": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "min_approvers": {"type": "integer", "minimum": 1},
            "approver_roles": {
              "type": "array",
              "items": {"type": "string"}
            },
            "auto_expire_seconds": {"type": "integer", "minimum": 60}
          }
        }
      }
    },
    "BreakGlassConfig": {
      "type": "object",
      "description": "Emergency access bypass configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "activation_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "system_unresponsive",
              "data_breach_suspected",
              "regulatory_demand",
              "operator_safety"
            ]
          }
        },
        "required_approvers": {
          "type": "integer",
          "minimum": 1,
          "default": 2
        },
        "approver_identities": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of identity IDs authorized to approve break-glass"
        },
        "max_duration_seconds": {
          "type": "integer",
          "minimum": 60,
          "default": 3600
        },
        "audit_level": {
          "type": "string",
          "enum": ["full", "enhanced"],
          "default": "full"
        },
        "notification_channels": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Channels to notify on break-glass activation"
        },
        "post_activation_review": {
          "type": "boolean",
          "default": true,
          "description": "Require post-incident review of break-glass usage"
        }
      }
    },
    "AuditConfig": {
      "type": "object",
      "properties": {
        "log_all_access": {
          "type": "boolean",
          "default": true
        },
        "log_denied_attempts": {
          "type": "boolean",
          "default": true
        },
        "retention_days": {
          "type": "integer",
          "minimum": 30,
          "default": 365
        },
        "export_format": {
          "type": "string",
          "enum": ["json", "csv", "parquet"]
        }
      }
    }
  }
}
