{
  "$id": "https://mindburn.ai/schemas/connectors/arc/arc_session_step.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARC Session Step Payload",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "color",
        "submit",
        "test_submit"
      ]
    },
    "coordinates": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer"
        },
        "y": {
          "type": "integer"
        }
      }
    },
    "value": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    }
  },
  "required": [
    "session_id",
    "action_type"
  ]
}
