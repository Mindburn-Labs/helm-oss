{
  "api_version": "integrations.helm.dev/v1",
  "provider": {
    "id": "stripe",
    "name": "Stripe",
    "category": "payments",
    "homepage": "https://stripe.com",
    "icon_url": "https://images.ctfassets.net/fzn2n1nzq965/HTTOloNPhisV9P4hlMPNA/cacf1bb88b9fc492dfad34378d844280/Stripe_icon_-_square.svg"
  },
  "connector": {
    "id": "stripe-v1",
    "version": "1.0.0",
    "packaging": "builtin",
    "artifact_digest": ""
  },
  "auth": {
    "methods": [
      {
        "type": "apikey",
        "apikey_config": {
          "header": "Authorization",
          "prefix": "Bearer "
        }
      }
    ]
  },
  "capabilities": [
    {
      "urn": "cap://stripe/list-charges@1.0.0",
      "name": "List Charges",
      "description": "List all payment charges",
      "risk_class": "E0",
      "idempotent": true,
      "rollback": false
    },
    {
      "urn": "cap://stripe/create-charge@1.0.0",
      "name": "Create Charge",
      "description": "Create a payment charge",
      "risk_class": "E3",
      "idempotent": false,
      "rollback": true
    },
    {
      "urn": "cap://stripe/list-subscriptions@1.0.0",
      "name": "List Subscriptions",
      "description": "List all active subscriptions",
      "risk_class": "E0",
      "idempotent": true,
      "rollback": false
    }
  ],
  "runtime": {
    "kind": "http",
    "config": {
      "base_url": "https://api.stripe.com/v1"
    }
  },
  "policies_default": {
    "max_requests_per_minute": 100,
    "max_cost_cents_per_day": 100000,
    "host_allowlist": ["api.stripe.com"],
    "data_class_restriction": ["financial", "pii"]
  },
  "evidence_default": {
    "retention_days": 365,
    "redaction_rules": ["card_number", "cvc", "exp_month", "exp_year"]
  },
  "tests": {
    "smoke": [
      {
        "name": "list_charges",
        "capability_urn": "cap://stripe/list-charges@1.0.0",
        "expect_status": 200,
        "timeout_seconds": 10
      }
    ]
  },
  "ui": {
    "category": "Payments",
    "short_description": "Process payments, manage subscriptions, and view charges via Stripe.",
    "install_steps": [
      {
        "order": 1,
        "action_type": "api_key_input",
        "title": "Enter API Key",
        "description": "Provide your Stripe secret API key (starts with sk_)."
      }
    ],
    "warnings": [
      "This connector handles financial data. Ensure PCI compliance.",
      "Use a restricted key in production — never your root secret key."
    ]
  }
}
